# Copy this to .env.e2e and fill in the DATABASE_URL for your Neon E2E branch
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST.neon.tech/neondb?sslmode=require
AUTH_SECRET=e2e-test-auth-secret-minimum-32-characters-long
AUTH_URL=http://localhost:3500
NEXTAUTH_URL=http://localhost:3500
WATERMARK_SECRET=e2e-watermark-secret
AUTH_PASSWORD_ENABLED=true
